# ==============================================================
# VARIÁVEIS DE AMBIENTE DO BACKEND (Node.js)
# ==============================================================

# Porta em que o servidor Node.js vai rodar
PORT=3000

# --------------------------------------------------------------
# Configurações do Banco de Dados MySQL (aaPanel / Servidor VPN)
# --------------------------------------------------------------
DB_HOST=217.196.60.62
DB_USER=mysql
DB_PASSWORD=Miguel@18032018
DB_DATABASE=digitalplussmysql
DB_PORT=3301

# --------------------------------------------------------------
# Autenticação e Segurança
# --------------------------------------------------------------
# Chave secreta usada para gerar os tokens de login (JWT) das funcionárias.
# Em produção, mude para uma string longa e aleatória.
JWT_SECRET=super_chave_secreta_studio_mythos_crm_2026

# --------------------------------------------------------------
# Integrações de Terceiros (Opcionais / Futuras)
# --------------------------------------------------------------
# Chave da API oficial do WhatsApp ou provedor (ex: Z-API, Twilio)
WHATSAPP_API_TOKEN=inserir_seu_token_do_whatsapp_aqui

# Chave da API do Google Gemini (para atendimento via IA no WhatsApp)
GEMINI_API_KEY=inserir_sua_chave_gemini_aqui
# Modelo Gemini a usar (padrão: gemini-2.5-flash-lite — rápido e barato; use gemini-2.5-flash ou gemini-2.5-pro para mais capacidade)
# gemini-2.0-flash e gemini-2.0-flash-lite foram DESCONTINUADOS pelo Google (retornam 404).
GEMINI_MODEL=gemini-2.5-flash-lite
# Modelo usado automaticamente se o principal ficar sobrecarregado (erro 503) mesmo após os retries
GEMINI_MODEL_FALLBACK=gemini-2.5-flash

# --------------------------------------------------------------
# Bot WhatsApp (whatsapp-web.js + IA Gemini)
# --------------------------------------------------------------
# Define true para iniciar o bot automaticamente com o servidor
WHATSAPP_ENABLED=false

# Chave da Google Places API (New) — prospecção com dados completos do Maps.
# Habilite "Places API (New)" no Google Cloud e cole a chave abaixo.
# ⚠️ Em produção o .env é ignorado pelo Docker (.dockerignore): defina esta
# variável como env var no EasyPanel.
GOOGLE_MAPS_API_KEY=inserir_sua_chave_google_places_aqui